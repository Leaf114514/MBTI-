
.container {
  padding: 32rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 32rpx;
}

.status {
  margin-top: 24rpx;
  color: #666;
}

.user-card {
  margin-top: 32rpx;
  padding: 24rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  background: #fafafa;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  margin-top: 20rpx;
  border-radius: 50%;
}