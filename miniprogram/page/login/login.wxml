<!--pages/login/login.wxml-->
<view class="login-page">
  <!-- 左上角切换按钮 -->
  <view class="toggle-btn {{toggleShaking ? 'toggle-shake' : ''}}" bindtap="toggleShapes">
    <text class="toggle-label">{{toggleLabel}}</text>
  </view>

  <!-- 掉落几何图形 — 始终渲染，用 class 控制显隐避免重置动画 -->
  <view class="shapes-container {{shapesVisible ? '' : 'shapes-hidden'}}">
    <view
      wx:for="{{shapes}}"
      wx:key="index"
      class="shape shape-{{item.type}}"
      style="{{item.inlineStyle}}"
    ></view>
  </view>

  <view class="login-title">
    <view class="title-letters">
      <text class="title-letter" style="-webkit-text-stroke: 1rpx {{letterColors[0]}}; text-shadow: 0 0 12rpx {{letterColors[0]}}, 0 0 24rpx {{letterColors[0]}};">M</text>
      <text class="title-letter" style="-webkit-text-stroke: 1rpx {{letterColors[1]}}; text-shadow: 0 0 12rpx {{letterColors[1]}}, 0 0 24rpx {{letterColors[1]}};">B</text>
      <text class="title-letter" style="-webkit-text-stroke: 1rpx {{letterColors[2]}}; text-shadow: 0 0 12rpx {{letterColors[2]}}, 0 0 24rpx {{letterColors[2]}};">T</text>
      <text class="title-letter" style="-webkit-text-stroke: 1rpx {{letterColors[3]}}; text-shadow: 0 0 12rpx {{letterColors[3]}}, 0 0 24rpx {{letterColors[3]}};">I</text>
    </view>
    <text class="title-suffix">洞察</text>
  </view>

  <view class="title-divider"></view>

  <text class="login-slogan">{{currentSlogan}}</text>

  <button
    class="login-btn {{btnShaking ? 'login-btn-shake' : ''}}"
    bindtap="handleWechatLogin"
    disabled="{{btnDisabled}}"
  >
    {{btnText}}
  </button>
</view>
