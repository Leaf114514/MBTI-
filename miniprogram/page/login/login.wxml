<!--pages/login/login.wxml-->

<!--微信快捷登录按钮-->
<view class="login_father">
  <image
    class="login_image"
    src="../../image/zhanweifu.png"
    mode="aspectFit"
  />

  <view class="title">{{message}}</view>
    <button 
      class="LoginButton"
      type="primary"
      bindtap="handleWechatLogin"
      open-type="getUserInfo"  
       >
      微信快捷登录
    </button>
  
    </view>
