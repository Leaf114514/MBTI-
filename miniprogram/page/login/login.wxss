.container {
  padding: 32rpx;
}



.login_father{
  min-height: 70vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 0 32rpx;
  box-sizing: border-box;
  transform: translateY(-8vh);
}

.login_image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: -30rpx;
}

.title {
  font-size: 36rpx;
  margin-bottom: 15rpx;
  text-align: center;
}

.LoginButton {
  width: 60%;
  margin: 0 auto;
}
