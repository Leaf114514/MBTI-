.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
  background-color: #ffffff;
}

.header {
  margin-top: 100rpx;
  text-align: center;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333333;
  display: block;
}

.subtitle {
  font-size: 28rpx;
  color: #999999;
  margin-top: 20rpx;
  display: block;
}

.main-content {
  flex: 1;
}

.footer {
  width: 100%;
  margin-bottom: 120rpx; /* 为底栏留出空间 */
}

.start-btn {
  background-color: #333333;
  color: #ffffff;
  border-radius: 50rpx;
  font-size: 32rpx;
  padding: 20rpx 60rpx;
  border: none;
}
