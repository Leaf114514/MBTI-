.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx 24rpx;
  background: #f5f7fb;
}

.article-wrapper {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(31, 42, 55, 0.08);
}

.article-cover {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
}

.article-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #1f2a37;
}

.article-content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #334155;
}
