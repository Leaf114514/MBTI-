page {
  min-height: 100%;
  background: #ffffff;
}

.container {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 0 0 40rpx;
  background: #ffffff;
}

.article-wrapper {
  display: flex;
  flex-direction: column;
  background: #ffffff;
}

.article-cover {
  display: block;
  width: 100%;
  height: 420rpx;
  background: #f3f4f6;
}

.article-header {
  padding: 32rpx 24rpx 0;
}

.article-title {
  display: -webkit-box;
  overflow: hidden;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.5;
  color: #1f2937;
}

.author-row {
  display: flex;
  align-items: center;
  margin-top: 24rpx;
}

.author-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #e5e7eb;
}

.author-meta {
  display: flex;
  align-items: center;
  margin-left: 16rpx;
}

.author-name {
  font-size: 24rpx;
  color: #111827;
}

.publish-time {
  margin-left: 16rpx;
  font-size: 24rpx;
  color: #94a3b8;
}

.article-body {
  padding: 32rpx 24rpx 0;
}

.article-paragraph {
  display: block;
  margin-bottom: 24rpx;
  font-size: 28rpx;
  line-height: 1.8;
  color: #334155;
  word-break: break-word;
}

.article-image {
  display: block;
  width: 100%;
  margin: 8rpx 0 32rpx;
  border-radius: 16rpx;
  background: #e5e7eb;
}
