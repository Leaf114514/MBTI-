<view class="style_edit_btn" > <text bindtap="goToProfile">编辑</text></view>
<view class="front_end_file">
    <!-- 头像框 -->
<view class="avatar">
  <image class="avatar_image" src="{{avatarUrl}}" mode="aspectFill"/>
</view>

   <!-- 名字栏 -->
<view class="attribute_box" >
   <text class="attribute_value">{{userName || '名字未设置'}}</text>
  </view>
   <!-- 属性栏 -->
  <view class="attribute_box" >
   <text class="attribute_value">{{gender || '性别未设置'}}</text>
   <text class="attribute_value">{{tempBirthday || '生日未设置'}}</text>
  </view>
</view>





