.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
  background-color: #ffffff;
}

.header {
  margin-bottom: 60rpx;
  text-align: center;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333333;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: #999999;
  margin-top: 10rpx;
  display: block;
}

.mbti-list {
  flex: 1;
}

.mbti-item {
  background-color: #f8f8f8;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.mbti-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

.mbti-desc {
  font-size: 26rpx;
  color: #666666;
}
